rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read stories (public data)
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User profiles - only authenticated users can read/write their own
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // User history - only authenticated users can read/write their own
    match /users/{userId}/history/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // User results - only authenticated users can read/write their own
    match /results/{resultId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // User bookmarks
    match /users/{userId}/bookmarks/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }

    // Recordings
    match /recordings/{recordingId} {
      allow read, write: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
